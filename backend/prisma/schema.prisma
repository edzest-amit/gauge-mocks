generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleScope {
  PLATFORM
  TENANT
}

model Tenant {
  id         String   @id @default(uuid())
  name       String
  slug       String   @unique
  created_at DateTime @default(now())

  users User[]
  roles Role[]
  subjects Subject[]
  topics   Topic[]
  concepts Concept[]
}

model User {
  id            String   @id @default(uuid())
  tenant_id     String
  email         String
  password_hash String
  created_at    DateTime @default(now())

  tenant Tenant @relation(fields: [tenant_id], references: [id])

  user_roles UserRole[]

  @@unique([tenant_id, email])
}

model Role {
  id         String   @id @default(uuid())
  name       String
  scope      RoleScope @default(TENANT)
  tenant_id  String?
  created_at DateTime @default(now())

  tenant Tenant? @relation(fields: [tenant_id], references: [id])

  user_roles UserRole[]

  @@unique([tenant_id, name])
}

model UserRole {
  id         String   @id @default(uuid())
  user_id    String
  role_id    String
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id])
  role Role @relation(fields: [role_id], references: [id])

  @@unique([user_id, role_id])
}


// Exam Engine Models

model Subject {
  id          String   @id @default(uuid())
  tenant_id   String
  name        String
  description String?
  created_at  DateTime @default(now())

  tenant Tenant @relation(fields: [tenant_id], references: [id])

  topics Topic[]

  @@index([tenant_id])
  @@unique([tenant_id, name])
}

model Topic {
  id          String   @id @default(uuid())
  tenant_id   String
  subject_id  String
  name        String
  description String?
  created_at  DateTime @default(now())

  tenant  Tenant  @relation(fields: [tenant_id], references: [id])
  subject Subject @relation(fields: [subject_id], references: [id])

  concepts Concept[]

  @@index([tenant_id, subject_id])
  @@unique([tenant_id, subject_id, name])
}

model Concept {
  id          String   @id @default(uuid())
  tenant_id   String
  topic_id    String
  name        String
  description String?
  created_at  DateTime @default(now())

  tenant Tenant @relation(fields: [tenant_id], references: [id])
  topic  Topic  @relation(fields: [topic_id], references: [id])

  @@index([tenant_id, topic_id])
  @@unique([tenant_id, topic_id, name])
}